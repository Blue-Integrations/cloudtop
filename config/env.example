# Copy to config/env or config/snmp.env (or /etc/cloudtop-monitor/env)
# and edit. Only unset env vars are applied; existing env wins.
#
# SNMP: name:host:port:community  or  name:host:port:community:ifindex
# ifindex = interface index (default 1). Use for WAN/first Ethernet if not 1.
# Find indices: snmpwalk -v2c -c c4ct1 192.168.88.1 1.3.6.1.2.1.2.2.1.2
# SNMP_TARGETS=192.168.88.1:161:c4ct1,172.16.10.1:161:c4ct1
# Or with interface: router1:192.168.88.1:161:c4ct1:1,router2:172.16.10.1:161:c4ct1:1
#
# LOCAL_SERVER_NAME=cloudtop
# MONITOR_USER=admin
# MONITOR_PASS=your-password
# PORT=3000
